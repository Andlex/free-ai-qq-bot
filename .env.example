# NoneBot2 配置
DRIVER=~fastapi+~httpx+~websockets
HOST=127.0.0.1
PORT=8080
LOG_LEVEL=INFO

# AI 后端配置
# auto = 自动检测（优先 OpenAI > Claude > MiMo）
# mimo = 免费 MiMo 模型（默认，无需 API Key）
# openai = OpenAI（需要 OPENAI_API_KEY）
# claude = Claude（需要 ANTHROPIC_API_KEY）
AI_BACKEND=auto

# MiMo 配置（免费，无需修改）
OPENCODE_BIN=mimo

# OpenAI 配置（可选）
# OPENAI_API_KEY=sk-xxx

# Claude 配置（可选）
# ANTHROPIC_API_KEY=sk-ant-xxx

# QQ Bot 配置
QQ_IS_SANDBOX=true
QQ_BOTS='[
  {
    "id": "你的AppID",
    "token": "你的AppSecret",
    "secret": "你的AppSecret",
    "intent": {
      "c2c_group_at_messages": true
    }
  }
]'
